# Environment variables for the Vercel deployment.
# Add these in Vercel dashboard -> Project -> Settings -> Environment Variables.
# None of this is needed for the GitHub Pages copy, which runs browser-only.

# Password to open the site. This is the ONLY thing standing between the
# internet and your Anthropic credits, so make it long and random.
SITE_PASSWORD=change-this-to-something-strong

# Long random string used to sign the session cookie. Mash the keyboard.
SESSION_SECRET=replace-with-a-long-random-string

# Your Anthropic API key. Lives only here — never sent to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# Provisioned automatically when you add an Upstash Redis store to the project
# (Vercel -> Storage -> Upstash Redis). You do NOT set these by hand. Either
# naming works:
#   KV_REST_API_URL + KV_REST_API_TOKEN            (legacy Vercel KV)
#   UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN   (Upstash Marketplace)
